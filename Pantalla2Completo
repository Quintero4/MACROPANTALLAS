Const HWND_TOP = 0
Const SWP_NOSIZE = &H1
Const SWP_SHOWWINDOW = &H40
Const SW_RESTORE = 9 ' Comando para des-maximizar temporalmente y permitir el movimiento

Public ProximoChequeo As Double

Sub ProbarAhoraMismo()
    Dim resultado As Boolean
    resultado = EjecutarAccionVideo(True)
End Sub

Sub MonitorearVideoAutomatico()
    Dim encontrado As Boolean
    encontrado = EjecutarAccionVideo(False)
    
    If Not encontrado Then
        ProximoChequeo = Now + TimeValue("00:00:02")
        Application.OnTime ProximoChequeo, "MonitorearVideoAutomatico"
    End If
End Sub

Function EjecutarAccionVideo(ModoPrueba As Boolean) As Boolean
    #If VBA7 Then
        Dim currHwnd As LongPtr
        Dim targetHwnd As LongPtr
    #Else
        Dim currHwnd As Long
        Dim targetHwnd As Long
    #End If
    
    Dim title As String, windowTitle As String
    Dim textLen As Long, xPantalla2 As Long
    Dim esNuevoPlayer As Boolean
    
    ' ===================================================================
    '  ¡AJUSTE DE PANTALLA AQUÍ!
    ' ===================================================================
    ' Si sigue apareciendo en la Pantalla 1, cambia este número:
    ' - Prueba con -1920 si tu Pantalla 2 está a la IZQUIERDA de la de Excel.
    ' - Prueba con 2560 o 3840 si tu pantalla de Excel es de mucha resolución.
    xPantalla2 = 1920 
    ' ===================================================================
    
    targetHwnd = 0
    currHwnd = FindWindowEx(0, 0, vbNullString, vbNullString)
    
    Do While currHwnd <> 0
        title = Space(255)
        textLen = GetWindowText(currHwnd, title, 255)
        
        If textLen > 0 Then
            windowTitle = Left(title, textLen)
            
            ' CORRECCIÓN: Buscamos "Heredado" o "Media Player"
            If InStr(1, windowTitle, "Heredado", vbTextCompare) > 0 Or _
               InStr(1, windowTitle, "Media Player", vbTextCompare) > 0 Then
                targetHwnd = currHwnd
                esNuevoPlayer = False
                Exit Do
            ElseIf InStr(1, windowTitle, "Reproductor de multimedia", vbTextCompare) > 0 Or _
                   InStr(1, windowTitle, "Películas", vbTextCompare) > 0 Then
                targetHwnd = currHwnd
                esNuevoPlayer = True
                Exit Do
            End If
        End If
        currHwnd = FindWindowEx(0, currHwnd, vbNullString, vbNullString)
    Loop
    
    If targetHwnd <> 0 Then
        ' 1. Forzar a que la ventana se "desbloquee" si estaba maximizada en la pantalla 1
        ShowWindow targetHwnd, SW_RESTORE
        DoEvents
        
        ' 2. Mover la ventana a la coordenada de la pantalla 2
        SetWindowPos targetHwnd, HWND_TOP, xPantalla2, 0, 0, 0, SWP_NOSIZE Or SWP_SHOWWINDOW
        Application.Wait (Now + TimeValue("00:00:01"))
        
        ' 3. Traer al frente y expandir a pantalla completa
        SetForegroundWindow targetHwnd
        DoEvents
        
        If esNuevoPlayer Then
            SendKeys "{F11}", True
        Else
            SendKeys "%{ENTER}", True
        End If
        
        If ModoPrueba Then MsgBox "¡Video detectado y enviado a la coordenada " & xPantalla2 & "!", vbInformation
        EjecutarAccionVideo = True
    Else
        If ModoPrueba Then MsgBox "No se detectó el reproductor. Asegúrate de tener el video reproduciéndose en pantalla.", vbExclamation
        EjecutarAccionVideo = False
    End If
End Function

Sub DetenerMonitoreo()
    On Error Resume Next
    Application.OnTime ProximoChequeo, "MonitorearVideoAutomatico", , False
End Sub



This WOrkbook

Private Sub Workbook_Open()
    ' Inicia la vigilancia automática en segundo plano apenas se abre este Excel
    Call MonitorearVideoAutomatico
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    ' Detiene el temporizador al cerrar el Excel para evitar errores
    Call DetenerMonitoreo
End Sub
