Const SWP_NOSIZE = &H1
Const SWP_NOZORDER = &H4
Const SWP_SHOWWINDOW = &H40
Const SW_RESTORE = 9

Const SM_CXSCREEN = 0
Const SM_XVIRTUALSCREEN = 76

Public ProximoChequeo As Double

' =======================================================
'  1. PRUEBA MANUAL (Dale a F5 aquí dentro con el video abierto)
' =======================================================
Sub ProbarAhoraMismo()
    Dim resultado As Boolean
    resultado = EjecutarAccionVideo(True)
End Sub

' =======================================================
'  2. BUCLE AUTOMÁTICO
' =======================================================
Sub MonitorearVideoAutomatico()
    Dim encontrado As Boolean
    encontrado = EjecutarAccionVideo(False)
    
    If Not encontrado Then
        ProximoChequeo = Now + TimeValue("00:00:02")
        Application.OnTime ProximoChequeo, "MonitorearVideoAutomatico"
    End If
End Sub

' =======================================================
'  3. FUNCIÓN PRINCIPAL DE CONTROL
' =======================================================
Function EjecutarAccionVideo(ModoPrueba As Boolean) As Boolean
    #If VBA7 Then
        Dim currHwnd As LongPtr
        Dim targetHwnd As LongPtr
    #Else
        Dim currHwnd As Long
        Dim targetHwnd As Long
    #End If
    
    Dim title As String, windowTitle As String
    Dim textLen As Long, xPantalla2 As Long
    Dim esNuevoPlayer As Boolean
    Dim xVirtual As Long, cxScreen As Long
    
    ' --- DETECCIÓN AUTOMÁTICA E INTELIGENTE DE TU PANTALLA 2 ---
    xVirtual = GetSystemMetrics(SM_XVIRTUALSCREEN)
    cxScreen = GetSystemMetrics(SM_CXSCREEN)
    
    If xVirtual < 0 Then
        ' Tu Pantalla 2 está situada a la IZQUIERDA de la principal
        xPantalla2 = xVirtual + 100
    Else
        ' Tu Pantalla 2 está situada a la DERECHA de la principal
        xPantalla2 = cxScreen + 100
    End If
    ' -----------------------------------------------------------
    
    targetHwnd = 0
    currHwnd = FindWindowEx(0, 0, vbNullString, vbNullString)
    
    Do While currHwnd <> 0
        ' FILTRO CRÍTICO: Comprobamos que la ventana sea VISIBLE en tu monitor
        If IsWindowVisible(currHwnd) <> 0 Then
            title = Space(255)
            textLen = GetWindowText(currHwnd, title, 255)
            
            If textLen > 0 Then
                windowTitle = Left(title, textLen)
                
                ' Búsqueda por el nombre que detectaste ("Heredado")
                If InStr(1, windowTitle, "Heredado", vbTextCompare) > 0 Or _
                   InStr(1, windowTitle, "Windows Media", vbTextCompare) > 0 Then
                    targetHwnd = currHwnd
                    esNuevoPlayer = False
                    Exit Do
                ElseIf InStr(1, windowTitle, "Reproductor de multimedia", vbTextCompare) > 0 Or _
                       InStr(1, windowTitle, "Películas", vbTextCompare) > 0 Then
                    targetHwnd = currHwnd
                    esNuevoPlayer = True
                    Exit Do
                End If
            End If
        End If
        currHwnd = FindWindowEx(0, currHwnd, vbNullString, vbNullString)
    Loop
    
    ' Si se localiza la ventana real del reproductor, se ejecutan las órdenes
    If targetHwnd <> 0 Then
        ' Desmaximizamos temporalmente para obligar a Windows a permitir el arrastre entre pantallas
        ShowWindow targetHwnd, SW_RESTORE
        DoEvents
        
        ' Movemos la ventana a la coordenada calculada de la pantalla 2
        SetWindowPos targetHwnd, 0, xPantalla2, 100, 0, 0, SWP_NOSIZE Or SWP_NOZORDER Or SWP_SHOWWINDOW
        Application.Wait (Now + TimeValue("00:00:01"))
        
        ' Traemos el reproductor al frente y lanzamos pantalla completa
        SetForegroundWindow targetHwnd
        DoEvents
        
        If esNuevoPlayer Then
            SendKeys "{F11}", True
        Else
            SendKeys "%{ENTER}", True
        End If
        
        If ModoPrueba Then MsgBox "¡Video detectado y enviado con éxito a la Pantalla 2! (Coordenada X calculada: " & xPantalla2 & ")", vbInformation
        EjecutarAccionVideo = True
    Else
        If ModoPrueba Then MsgBox "Excel no encontró ninguna ventana visible con el nombre de tu reproductor.", vbExclamation
        EjecutarAccionVideo = False
    End If
End Function

Sub DetenerMonitoreo()
    On Error Resume Next
    Application.OnTime ProximoChequeo, "MonitorearVideoAutomatico", , False
End Sub


This WOrkbook

Private Sub Workbook_Open()
    ' Inicia la vigilancia automática en segundo plano apenas se abre este Excel
    Call MonitorearVideoAutomatico
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    ' Detiene el temporizador al cerrar el Excel para evitar errores
    Call DetenerMonitoreo
End Sub
