Const HWND_TOP = 0
Const SWP_NOSIZE = &H1
Const SWP_SHOWWINDOW = &H40

' Variable global para controlar el temporizador
Public ProximoChequeo As Double

Sub MonitorearVideoAutomatico()
    #If VBA7 Then
        Dim currHwnd As LongPtr
        Dim targetHwnd As LongPtr
    #Else
        Dim currHwnd As Long
        Dim targetHwnd As Long
    #End If
    
    Dim title As String
    Dim textLen As Long
    Dim windowTitle As String
    Dim xPantalla2 As Long
    Dim esNuevoPlayer As Boolean
    
    ' --- CONFIGURACIÓN ---
    xPantalla2 = 1920 ' Píxel horizontal donde empieza tu pantalla 2
    ' ---------------------
    
    targetHwnd = 0
    currHwnd = FindWindowEx(0, 0, vbNullString, vbNullString)
    
    ' Escanear ventanas abiertas
    Do While currHwnd <> 0
        title = Space(255)
        textLen = GetWindowText(currHwnd, title, 255)
        
        If textLen > 0 Then
            windowTitle = Left(title, textLen)
            
            If InStr(1, windowTitle, "Windows Media Player", vbTextCompare) > 0 Then
                targetHwnd = currHwnd
                esNuevoPlayer = False
                Exit Do
            ElseIf InStr(1, windowTitle, "Reproductor de multimedia", vbTextCompare) > 0 Then
                targetHwnd = currHwnd
                esNuevoPlayer = True
                Exit Do
            End If
        End If
        currHwnd = FindWindowEx(0, currHwnd, vbNullString, vbNullString)
    Loop
    
    ' SI ENCUENTRA EL VIDEO: Lo mueve, lo maximiza y DETIENE el bucle automática mente
    If targetHwnd <> 0 Then
        SetWindowPos targetHwnd, HWND_TOP, xPantalla2, 0, 0, 0, SWP_NOSIZE Or SWP_SHOWWINDOW
        Application.Wait (Now + TimeValue("00:00:01"))
        SetForegroundWindow targetHwnd
        DoEvents
        
        If esNuevoPlayer Then
            SendKeys "{F11}", True
        Else
            SendKeys "%{ENTER}", True
        End If
        
        ' Ya cumplió su función, dejamos de monitorizar para no repetir el comando infinitamente
        Exit Sub
    End If
    
    ' SI NO ENCUENTRA EL VIDEO: Vuelve a buscar dentro de 2 segundos
    ProximoChequeo = Now + TimeValue("00:00:02")
    Application.OnTime ProximoChequeo, "MonitorearVideoAutomatico"
End Sub

Sub DetenerMonitoreo()
    On Error Resume Next
    Application.OnTime ProximoChequeo, "MonitorearVideoAutomatico", , False
End Sub


This WOrkbook

Private Sub Workbook_Open()
    ' Inicia la vigilancia automática en segundo plano apenas se abre este Excel
    Call MonitorearVideoAutomatico
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    ' Detiene el temporizador al cerrar el Excel para evitar errores
    Call DetenerMonitoreo
End Sub
