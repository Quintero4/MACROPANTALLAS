Private Sub Workbook_Open()
    ' ProgramOnamos el bloqueo para 1 segundo después de abrir.
    ' Esto permite a Excel terminar de cargar, quitar el logo y estar listo.
    DoEvents
    
    Application.DisplayAlerts = True
    Application.Visible = True
    Application.WindowState = xlMaximized
    
    DoEvents

    Application.OnTime Now + TimeValue("00:00:02"), "BloquearPantallaDos"
    Call BloquearPantallaDos
    
End Sub



