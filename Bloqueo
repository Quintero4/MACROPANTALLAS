Private Sub Workbook_Open()
    ' NUEVO: Minimiza la ventana de Excel de forma inmediata nada más abrirse
    Application.WindowState = xlMinimized
    
    ' Ejecuta el bloqueo persistente de la pantalla 2
    Call BloquearPantallaDos
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    ' Por seguridad, si se cierra el archivo, liberamos el ratón
    IsLocked = False
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
End Sub
