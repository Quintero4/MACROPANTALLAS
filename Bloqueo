Public Type RECT
    Left As Long
    Top As Long
    Right As Long
    Bottom As Long
End Type

' Declaraciones de la API de Windows (Añadimos GetAsyncKeyState para escuchar el teclado global)
#If VBA7 Then
    Public Declare PtrSafe Function LockCursor Lib "user32" Alias "ClipCursor" (lpRect As RECT) As Long
    Public Declare PtrSafe Function FreeCursor Lib "user32" Alias "ClipCursor" (ByVal lpRect As LongPtr) As Long
    Public Declare PtrSafe Sub Sleep Lib "kernel32" (ByVal dwMilliseconds As Long)
    Public Declare PtrSafe Function GetAsyncKeyState Lib "user32" (ByVal vKey As Long) As Integer
#Else
    Public Declare Function LockCursor Lib "user32" Alias "ClipCursor" (lpRect As RECT) As Long
    Public Declare Function FreeCursor Lib "user32" Alias "ClipCursor" (ByVal lpRect As Long) As Long
    Public Declare Sub Sleep Lib "kernel32" (ByVal dwMilliseconds As Long)
    Public Declare Function GetAsyncKeyState Lib "user32" (ByVal vKey As Long) As Integer
#End If

Public IsLocked As Boolean

Sub BloquearPantallaDos()
    Dim AreaPantallaPrincipal As RECT
    
    ' CONFIGURACIÓN: Límites de tu Pantalla 1
    AreaPantallaPrincipal.Left = 0
    AreaPantallaPrincipal.Top = 0
    AreaPantallaPrincipal.Right = 1920   ' <-- Cambia si tu resolución es otra
    AreaPantallaPrincipal.Bottom = 1080  ' <-- Cambia si tu resolución es otra
    
    IsLocked = True
    
    Do While IsLocked = True
        LockCursor AreaPantallaPrincipal
        
        ' COMPROBACIÓN GLOBAL DEL TECLADO:
        ' Detecta si se pulsan a la vez: CTRL (&H11), SHIFT (&H10) y la tecla U (&H55)
        ' Funciona incluso con Excel minimizado.
        If GetAsyncKeyState(&H11) < 0 And GetAsyncKeyState(&H10) < 0 And GetAsyncKeyState(&H55) < 0 Then
            Call DesbloquearPantallaDos
            Exit Do
        End If
        
        DoEvents 
        Sleep 30
    Loop
End Sub

Sub DesbloquearPantallaDos()
    IsLocked = False
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    MsgBox "Pantalla desbloqueada correctamente.", vbInformation, "Éxito"
End Sub





