Public Type RECT
    Left As Long
    Top As Long
    Right As Long
    Bottom As Long
End Type

#If VBA7 Then
    Public Declare PtrSafe Function LockCursor Lib "user32" Alias "ClipCursor" (lpRect As RECT) As Long
    Public Declare PtrSafe Function FreeCursor Lib "user32" Alias "ClipCursor" (ByVal lpRect As LongPtr) As Long
#Else
    Public Declare Function LockCursor Lib "user32" Alias "ClipCursor" (lpRect As RECT) As Long
    Public Declare Function FreeCursor Lib "user32" Alias "ClipCursor" (ByVal lpRect As Long) As Long
#End If

Sub BloquearPantallaDos()
    Dim AreaPantallaPrincipal As RECT
    
    ' CONFIGURACIÓN: Límites de tu Pantalla 1
    AreaPantallaPrincipal.Left = 0
    AreaPantallaPrincipal.Top = 0
    AreaPantallaPrincipal.Right = 1920   ' <-- Cambia por el ANCHO de tu pantalla 1 si es distinto
    AreaPantallaPrincipal.Bottom = 1080  ' <-- Cambia por el ALTO de tu pantalla 1 si es distinto
    
    ' Encierra el ratón en la pantalla principal
    LockCursor AreaPantallaPrincipal
End Sub

Sub DesbloquearPantallaDos()
    ' Libera el ratón inmediatamente
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
End Sub





