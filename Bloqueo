Private Sub Workbook_Open()
    ' Asigna automáticamente el atajo Ctrl + Shift + U a la macro de desbloqueo
    ' El símbolo ^ representa CTRL y el símbolo + representa SHIFT
    Application.OnKey "^+u", "DesbloquearPantallaDos"
    Application.OnKey "^+U", "DesbloquearPantallaDos"
    
    ' Opcional: Asigna Ctrl + Shift + B para volver a bloquear manualmente si lo necesitas
    Application.OnKey "^+b", "BloquearPantallaDos"
    Application.OnKey "^+B", "BloquearPantallaDos"
    
    ' Ejecuta el bloqueo de la pantalla de forma inmediata al abrir el Excel
    Call BloquearPantallaDos
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    ' Por seguridad, si cierran el Excel, liberamos los atajos y el ratón
    Application.OnKey "^+u"
    Application.OnKey "^+b"
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
End Sub
