Sub ConvertPPTXtoMP4()
    Dim ws As Worksheet
    Dim lastRow As Long
    Dim i As Long
    Dim pptApp As Object
    Dim pptPres As Object
    Dim folderPath As String
    Dim pptxPath As String
    Dim mp4Path As String
    Dim fso As Object
    Dim file As Object
    Dim folder As Object

    ' Establecer la hoja de trabajo de donde se leen las rutas
    Set ws = ThisWorkbook.Sheets("Rutas")

    ' Encontrar la última fila con datos en la columna A
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).row

    ' Crear instancias de PowerPoint y FileSystemObject
    Set pptApp = CreateObject("PowerPoint.Application")
    pptApp.Visible = True
    Set fso = CreateObject("Scripting.FileSystemObject")

    ' Procesar cada ruta en la columna A
    For i = 1 To lastRow
        folderPath = ws.Cells(i, 1).Value

        ' Verificar si la ruta del directorio existe
        If Dir(folderPath, vbDirectory) <> "" Then
            Set folder = fso.GetFolder(folderPath)
            
            ' Buscar todos los archivos dentro de la carpeta
            For Each file In folder.Files
                ' Filtrar solo archivos PPTX (evitando los archivos temporales de Office que empiezan por ~$)
                If LCase(file.Name) Like "*.pptx" And Not LCase(file.Name) Like "~$*" Then
                    
                    pptxPath = folderPath & "\" & file.Name
                    
                    ' Definir el nombre específico para el MP4 (mismo nombre que el PPTX pero con extensión .mp4)
                    mp4Path = folderPath & "\" & Left(file.Name, InStrRev(file.Name, ".") - 1) & ".mp4"

                    ' Garantizar la sobrescritura: Si el archivo MP4 ya existe de ayer, lo borramos primero
                    If fso.FileExists(mp4Path) Then
                        On Error Resume Next
                        Kill mp4Path
                        On Error GoTo 0
                    End If

                    ' Abrir la presentación
                    Set pptPres = pptApp.Presentations.Open(pptxPath)

                    ' Crear el video MP4
                    ' Parámetros: Ruta, UsarTiempos, DuraciónDiapositiva, ResoluciónVertical(1080p), FPS(30), Calidad
                    pptPres.CreateVideo mp4Path, True, 5, 1080, 30, 85

                    ' Bucle de espera crucial: Evita que se cierre PowerPoint antes de terminar el renderizado
                    ' El estado 1 (ppMediaTaskStatusInProgress) significa que sigue procesando
                    Do While pptPres.CreateVideoStatus = 1
                        DoEvents ' Permite que Excel y Windows sigan respondiendo
                        Application.Wait Now + TimeValue("0:00:01")
                    Loop

                    ' Cerrar la presentación una vez finalizado el video
                    pptPres.Close
                    Set pptPres = Nothing
                End If
            Next file
        End If
    Next i

    ' Cerrar la aplicación de PowerPoint y liberar memoria
    pptApp.Quit
    Set pptApp = Nothing
    Set fso = Nothing

End Sub
