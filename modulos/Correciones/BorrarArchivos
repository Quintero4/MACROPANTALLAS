Sub BorrarArchivosPPTX()
    Dim ws As Worksheet
    Dim ultimaFila As Long
    Dim i As Long
    Dim ruta As String
    Dim archivo As String
    Dim fso As Object
    Dim carpeta As Object
    Dim subcarpeta As Object

    ' Establecer la hoja de trabajo
    Set ws = ThisWorkbook.Sheets("Rutas") 

    ' Encontrar la última fila con datos en la columna A
    ultimaFila = ws.Cells(ws.Rows.Count, "A").End(xlUp).row 

    ' Crear una instancia de FileSystemObject
    Set fso = CreateObject("Scripting.FileSystemObject") [cite: 1-2]

    ' Recorrer cada celda en la columna A
    For i = 1 To ultimaFila [cite: 2]
        ruta = ws.Cells(i, 1).Value [cite: 2]

        ' Verificar si la ruta no está vacía
        If ruta <> "" Then [cite: 2]
            ' Verificar si la ruta existe
            If fso.FolderExists(ruta) Then [cite: 2]
 
                ' 1. Eliminar todos los archivos .pptx en la ruta [cite: 3]
                archivo = Dir(ruta & "\*.pptx") [cite: 3]
                Do While archivo <> "" [cite: 3]
                    Kill ruta & "\" & archivo [cite: 3]
                    archivo = Dir [cite: 4]
                Loop

                ' 2. Eliminar todos los archivos .mp4 en la ruta (Añadido)
                archivo = Dir(ruta & "\*.mp4")
                Do While archivo <> ""
                    Kill ruta & "\" & archivo
                    archivo = Dir
                Loop

                ' Eliminar todas las carpetas dentro de la ruta [cite: 4]
                Application.Wait Now + TimeValue("0:00:05") [cite: 4]
                Set carpeta = fso.GetFolder(ruta) [cite: 4]
            
                For Each subcarpeta In carpeta.subFolders [cite: 5]
                    ' Establecer atributos a normal
                    subcarpeta.Attributes = 0 [cite: 5]
                    ' Intentar eliminar la carpeta
                    On Error Resume Next [cite: 5-6]
                    fso.DeleteFolder subcarpeta.path, True [cite: 6]
                    On Error GoTo 0 [cite: 7]
                Next subcarpeta
            End If
        End If
    Next i
End Sub
