Private Sub Workbook_Open()
    Application.DisplayAlerts = True
    Application.Visible = True
    Application.WindowState = xlMaximized
    DoEvents
    
    Application.OnTime Now + TimeValue("00:00:02"), "BloquearPantallaDos"
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    Dim ClaveCorrecta As String
    Dim ClaveIngresada As String
    
    ' CONFIGURACIÓN: Tu contraseña secreta
    ClaveCorrecta = "TuContraseña123" 
    
    ' 1. Liberamos temporalmente el cursor para que puedan escribir en el InputBox
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    DoEvents
    
    ClaveIngresada = InputBox("Introduce la contraseña para poder cerrar este archivo concretamente:", _
                              "Confirmación de Cierre Requerida")
    
    ' 2. Evaluamos la contraseña
    If ClaveIngresada = ClaveCorrecta Then
        ' Si es correcta, desbloqueamos todo permanentemente y dejamos cerrar
        Call DesbloquearPantallaDos
    Else
        ' Si es incorrecta o cancela, impedimos que el archivo se cierre
        Cancel = True
        
        ' Mostramos el mensaje de error (durante este aviso el mouse se moverá libremente por diseño de Windows)
        MsgBox "Contraseña incorrecta. El bloqueo de pantalla permanecerá activo.", vbCritical, "Acceso Denegado"
        
        ' NUEVO Y CRÍTICO: En el milisegundo en que el usuario hace clic en "Aceptar" del MsgBox,
        ' reactivamos el bloqueo usando la variable global antes de regresar al bucle principal.
        LockCursor AreaPantallaPrincipal
    End If
End Sub
