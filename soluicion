Private Sub Workbook_Open()
    Application.DisplayAlerts = True
    Application.Visible = True
    Application.WindowState = xlMaximized
    DoEvents
    
    Application.OnTime Now + TimeValue("00:00:02"), "BloquearPantallaDos"
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    Dim ClaveCorrecta As String
    Dim ClaveIngresada As String
    
    ' CONFIGURACIÓN: Tu contraseña secreta
    ClaveCorrecta = "TuContraseña123" 
    
    ' 1. Liberamos temporalmente el cursor para usar el InputBox sin problemas
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    DoEvents
    
    ClaveIngresada = InputBox("Introduce la contraseña para poder cerrar este archivo:", _
                              "Confirmación de Cierre")
    
    ' 2. Evaluamos la contraseña
    If ClaveIngresada = ClaveCorrecta Then
        ' Si es correcta, liberamos el ratón por completo y dejamos cerrar
        Call DesbloquearPantallaDos
    Else
        ' Si es incorrecta o presionan Cancelar:
        Cancel = True ' Abortamos el cierre del archivo
        
        MsgBox "Contraseña incorrecta. El bloqueo de pantalla permanecerá activo.", vbCritical, "Acceso Denegado"
        
        ' SOLUCIÓN: Volvemos a MINIMIZAR este Excel inmediatamente.
        ' Esto limpia tu pantalla no bloqueada para que puedas seguir usándola al 100%.
        Application.WindowState = xlMinimized
        DoEvents
        
        ' Al salir de aquí, el bucle "BloquearPantallaDos" que sigue corriendo de fondo
        ' reaplicará el candado de forma limpia en su siguiente ciclo, sin quedarse atrapado en la X.
    End If
End Sub
