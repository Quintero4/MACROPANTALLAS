Public Type RECT
    Left As Long
    Top As Long
    Right As Long
    Bottom As Long
End Type

#If VBA7 Then
    Public Declare PtrSafe Function LockCursor Lib "user32" Alias "ClipCursor" (lpRect As RECT) As Long
    Public Declare PtrSafe Function FreeCursor Lib "user32" Alias "ClipCursor" (ByVal lpRect As LongPtr) As Long
    Public Declare PtrSafe Sub Sleep Lib "kernel32" (ByVal dwMilliseconds As Long)
    Public Declare PtrSafe Function GetAsyncKeyState Lib "user32" (ByVal vKey As Long) As Integer
#Else
    Public Declare Function LockCursor Lib "user32" Alias "ClipCursor" (lpRect As RECT) As Long
    Public Declare Function FreeCursor Lib "user32" Alias "ClipCursor" (ByVal lpRect As Long) As Long
    Public Declare Sub Sleep Lib "kernel32" (ByVal dwMilliseconds As Long)
    Public Declare Function GetAsyncKeyState Lib "user32" (ByVal vKey As Long) As Integer
#End If

Public IsLocked As Boolean
Public AreaPantallaPrincipal As RECT 

Sub BloquearPantallaDos()
    Application.Visible = True
    DoEvents
    
    Application.WindowState = xlMinimized
    DoEvents
    
    ' CONFIGURACIÓN: Límites de tu Pantalla 1
    AreaPantallaPrincipal.Left = 0
    AreaPantallaPrincipal.Top = 0
    AreaPantallaPrincipal.Right = 3840   
    AreaPantallaPrincipal.Bottom = 2160  
    
    IsLocked = True
    
    Do While IsLocked = True
        LockCursor AreaPantallaPrincipal
        
        If GetAsyncKeyState(&H11) < 0 And GetAsyncKeyState(&H10) < 0 And GetAsyncKeyState(&H55) < 0 Then
            Call DesbloquearPantallaDos
            Exit Do
        End If
        
        DoEvents
        Sleep 30
    Loop
End Sub

Sub DesbloquearPantallaDos()
    IsLocked = False
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    Application.WindowState = xlNormal
End Sub


work

Private Sub Workbook_Open()
    Application.DisplayAlerts = True
    Application.Visible = True
    Application.WindowState = xlMaximized
    DoEvents
    
    ' Corregido: Apuntamos directamente al módulo 'Candado'
    Application.OnTime Now + TimeValue("00:00:02"), "Candado.BloquearPantallaDos"
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    Dim ClaveCorrecta As String
    Dim ClaveIngresada As String
    
    ClaveCorrecta = "Kill" 
    
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    DoEvents
    
    ClaveIngresada = InputBox("Introduce la contraseña para poder cerrar este archivo:", _
                              "Confirmación de Cierre")
    
    If ClaveIngresada = ClaveCorrecta Then
        Call DesbloquearPantallaDos
    Else
        Cancel = True 
        
        MsgBox "Contraseña incorrecta o acción cancelada. El bloqueo de pantalla permanecerá activo.", vbCritical, "Acceso Denegado"
        
        ' Frenamos el bucle viejo para limpiar memoria
        IsLocked = False
        DoEvents
        
        ' Corregido: Forzamos el relanzamiento explícito apuntando al módulo 'Candado'
        Application.OnTime Now + TimeValue("00:00:01"), "Candado.BloquearPantallaDos"
    End If
End Sub
