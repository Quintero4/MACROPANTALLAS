Private Sub Workbook_Open()
    Application.DisplayAlerts = True
    Application.Visible = True
    Application.WindowState = xlMaximized
    DoEvents
    
    Application.OnTime Now + TimeValue("00:00:02"), "BloquearPantallaDos"
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    Dim ClaveCorrecta As String
    Dim ClaveIngresada As String
    
    ' CONFIGURACIÓN: Tu contraseña secreta
    ClaveCorrecta = "Kill" 
    
    ' 1. Liberamos temporalmente el cursor para interactuar con el InputBox
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    DoEvents
    
    ClaveIngresada = InputBox("Introduce la contraseña para poder cerrar este archivo:", _
                              "Confirmación de Cierre")
    
    ' 2. Evaluamos la contraseña
    If ClaveIngresada = ClaveCorrecta Then
        ' Si es correcta, liberamos el ratón permanentemente y cerramos
        Call DesbloquearPantallaDos
    Else
        ' Si la contraseña es incorrecta, presionan Cancelar o cierran la ventana (X):
        Cancel = True ' Abortamos el cierre del archivo de forma fulminante
        
        MsgBox "Contraseña incorrecta o acción cancelada. El bloqueo de pantalla permanecerá activo.", vbCritical, "Acceso Denegado"
        
        ' 3. Forzamos la detención del bucle antiguo para evitar hilos duplicados o corruptos en memoria
        IsLocked = False
        DoEvents
        
        ' 4. SOLUCIÓN CRÍTICA: Volvemos a lanzar la función principal con 1 segundo de retraso.
        ' Esto le da tiempo a Excel para abortar el cierre y, justo después, vuelve a ejecutar
        ' "BloquearPantallaDos" de forma nativa (minimizando el archivo y atrapando el ratón en la pantalla 1).
        Application.OnTime Now + TimeValue("00:00:01"), "BloquearPantallaDos"
    End If
End Sub
