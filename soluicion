Private Sub Workbook_Open()
    ' Programamos la apertura limpia y asíncrona (como en la solución anterior)
    Application.DisplayAlerts = True
    Application.Visible = True
    Application.WindowState = xlMaximized
    DoEvents
    
    Application.OnTime Now + TimeValue("00:00:02"), "BloquearPantallaDos"
End Sub

Private Sub Workbook_BeforeClose(Cancel As Boolean)
    Dim ClaveCorrecta As String
    Dim ClaveIngresada As String
    
    ' =======================================================
    ' CONFIGURACIÓN: Cambia aquí tu contraseña secreta
    ClaveCorrecta = "TuContraseña123" 
    ' =======================================================
    
    ' 1. Liberamos temporalmente el cursor para que el usuario pueda
    ' interactuar con el cuadro de texto sin restricciones.
    #If VBA7 Then
        FreeCursor 0
    #Else
        FreeCursor 0&
    #End If
    DoEvents
    
    ' 2. Solicitamos la contraseña mediante un InputBox flotante
    ClaveIngresada = InputBox("Este archivo del sistema está protegido." & vbCrLf & vbCrLf & _
                              "Introduce la contraseña para poder cerrarlo:", _
                              "Confirmación de Cierre")
    
    ' 3. Evaluamos la contraseña introducida
    If ClaveIngresada = ClaveCorrecta Then
        ' Si es correcta, ejecutamos la rutina de limpieza para liberar el cursor permanentemente
        Call DesbloquearPantallaDos
        ' Cancel se queda en False, permitiendo que el archivo se cierre definitivamente
    Else
        ' Si la contraseña está vacía, es errónea o presionaron "Cancelar"
        MsgBox "Contraseña incorrecta. El archivo permanecerá abierto y bloqueado.", vbCritical, "Acceso Denegado"
        
        ' CRÍTICO: Cancelamos el cierre de ESTE libro de Excel
        Cancel = True
        
        ' Al salir de este evento, como "Cancel = True", el archivo no se cierra 
        ' y el bucle infinito de "BloquearPantallaDos" vuelve a tomar el control atrapando el cursor otra vez.
    End If
End Sub
